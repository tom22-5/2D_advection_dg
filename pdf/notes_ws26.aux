\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Average number of GMRES iterations for RK methods using Pazner's $r=1$ base preconditioner augmented with a randomized Woodbury update of sketch ranks $k \in \{2, 4, 8, 16\}$. Notice the convergence to the exact $r=2$ iteration baseline at $k=16$.\relax }}{5}{table.caption.3}\protected@file@percent }
\newlabel{tab:woodbury_k_comparison}{{3}{5}{Average number of GMRES iterations for RK methods using Pazner's $r=1$ base preconditioner augmented with a randomized Woodbury update of sketch ranks $k \in \{2, 4, 8, 16\}$. Notice the convergence to the exact $r=2$ iteration baseline at $k=16$.\relax }{table.caption.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Total runtime (in seconds) for RK methods using Pazner's $r=1$ base preconditioner augmented with a randomized Woodbury update of sketch ranks $k$. Notice that increasing the rank to $k=16$ yields the fastest overall runtimes due to the drastic reduction in GMRES iterations.\relax }}{5}{table.caption.4}\protected@file@percent }
\newlabel{tab:woodbury_runtime}{{4}{5}{Total runtime (in seconds) for RK methods using Pazner's $r=1$ base preconditioner augmented with a randomized Woodbury update of sketch ranks $k$. Notice that increasing the rank to $k=16$ yields the fastest overall runtimes due to the drastic reduction in GMRES iterations.\relax }{table.caption.4}{}}
